# Argus — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# Timezone
TZ=Europe/London

# USB webcam device (run: ls /dev/video*)
WEBCAM_DEVICE=/dev/video0

# Where Frigate stores recordings (USB SSD recommended)
RECORDINGS_PATH=./data/recordings

# ─── Voice assistant ──────────────────────────────────────────────────────────

# Path to Frigate's SQLite database (matches the frigate-db Docker volume)
FRIGATE_DB_PATH=./data/db/frigate.db

# MQTT broker (Mosquitto running in Docker)
MQTT_HOST=localhost
MQTT_PORT=1883

# Audio input device index (run: python3 -c "import sounddevice; print(sounddevice.query_devices())")
AUDIO_INPUT_DEVICE=0

# hailo-ollama LLM server (runs on host, started by install_hailo.sh)
HAILO_OLLAMA_URL=http://localhost:8000
HAILO_OLLAMA_MODEL=qwen2:1.5b

# How much Frigate event history to send to the LLM
VOICE_CONTEXT_HOURS=24
VOICE_CONTEXT_EVENTS=20
